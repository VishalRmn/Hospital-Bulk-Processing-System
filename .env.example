# Hospital Bulk Processing System Configuration
# Copy this file to .env and update values as needed

# Flask environment
FLASK_ENV=development

# Hospital Directory API
HOSPITAL_API_URL=https://hospital-directory.onrender.com

# Request settings
REQUEST_TIMEOUT=10
MAX_RETRIES=3

# Batch processing
MAX_BATCH_SIZE=20

# Logging
LOG_LEVEL=INFO

# Data persistence
DATA_DIR=data
